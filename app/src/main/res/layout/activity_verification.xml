<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="5dp"
            android:background="@drawable/button_back"
            android:contentDescription="Назад"
            android:onClick="OnBack" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inclined"
            android:gravity="center"
            android:text="ОТП Проверка"
            android:textColor="@color/black"
            android:textSize="14pt"
            android:importantForAccessibility="yes" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inclined"
            android:gravity="center"
            android:text="Пожалуйста, проверьте свою электронную почту, чтобы увидеть код подтверждения."
            android:textColor="#707B81"
            android:textSize="8pt"
            android:importantForAccessibility="yes" />

        <TextView
            android:id="@+id/otp_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inclined"
            android:text="OTP код:"
            android:textColor="@color/black"
            android:textSize="8pt"
            android:importantForAccessibility="yes"
            android:labelFor="@id/number1" />

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <TableRow>

                <!-- Цифра 1 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number1"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1"
                    android:nextFocusForward="@id/number2"/>

                <!-- Цифра 2 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number2"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:layout_marginLeft="12dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1"
                    android:nextFocusForward="@id/number3"/>

                <!-- Цифра 3 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number3"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:layout_marginLeft="12dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1"
                    android:nextFocusForward="@id/number4" />

                <!-- Цифра 4 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number4"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:layout_marginLeft="12dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1"
                    android:nextFocusForward="@id/number5" />

                <!-- Цифра 5 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number5"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:layout_marginLeft="12dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1"
                    android:nextFocusForward="@id/number6" />

                <!-- Цифра 6 -->
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/number6"
                    style="@style/EditText"
                    android:layout_width="46dp"
                    android:layout_height="99dp"
                    android:layout_marginLeft="12dp"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:layout_weight="0.16"
                    android:maxLength="1" />

            </TableRow>
        </TableLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inclined"
                android:layout_marginTop="8dp"
                android:text="Отправить заново"
                android:textColor="#707B81"
                android:textSize="12sp"
                android:importantForAccessibility="yes" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="00:30"
                android:textColor="#707B81"
                android:textSize="12sp"
                android:gravity="right"
                android:importantForAccessibility="yes"
                android:contentDescription="Таймер обратного отсчёта: 30 секунд" />

            <TextView
                android:id="@+id/send_mail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Отправить"
                android:textStyle="bold"
                android:textColor="#48B2E7"
                android:textSize="12sp"
                android:gravity="right"
                android:visibility="gone"
                android:onClick="OnSendMail"
                android:importantForAccessibility="yes"
                android:contentDescription="Кнопка повторной отправки кода подтверждения" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/user_email"
            style="@style/EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:hint="xyz@gmail.com"
            android:visibility="gone"
            android:importantForAccessibility="noHideDescendants" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>